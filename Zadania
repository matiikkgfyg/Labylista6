    // === TUTAJ DEFINIUJEMY STRUKTURY ZGODNIE Z WYKŁADEM ===
    public struct Point
    {
        public int x, y;
        public Point(int x, int y) { this.x = x; this.y = y; }
        public double CalculateDistance(Point other)
        {
            return Math.Sqrt(Math.Pow(other.x - this.x, 2) + Math.Pow(other.y - this.y, 2));
        }
    }

    public struct Rectangle
    {
        public int x, y;
        public double width, height;
        public void DisplayInfo()
        {
            Console.WriteLine($"\nNarożniki: ({x},{y}), ({x + width},{y}), ({x},{y + height}), ({x + width},{y + height})");
            Console.WriteLine($"Pole prostokąta: {Math.Round(width * height, 2)}");
        }
    }

    public struct Date
    {
        public int day, month, year;
        public Date(int day, int month, int year) { this.day = day; this.month = month; this.year = year; }
        public bool IsValid()
        {
            return DateTime.TryParse($"{year}-{month}-{day}", out _);
        }
        public void Display()
        {
            string status = IsValid() ? "jest prawidłowa." : "jest NIEPRAWIDŁOWA.";
            Console.WriteLine($"Data {day:D2}-{month:D2}-{year} {status}");
        }
    }

    public struct Student
    {
        public string FirstName, LastName, FieldOfStudy;
        public int IndexNumber;
        public double Scholarship;
        public void DisplayInfo()
        {
            Console.WriteLine($"- {FirstName} {LastName}, Kierunek: {FieldOfStudy}, Indeks: {IndexNumber}, Stypendium: {Scholarship} zł");
        }
    }

