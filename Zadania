        // --- ZADANIE 1 ---
        static void Zadanie1_GetText()
        {
            Console.Write("Wpisz dowolny tekst: ");
            string text = Console.ReadLine();

            Console.WriteLine("Wielkie litery: " + text.ToUpper());
            Console.WriteLine("Male litery: " + text.ToLower());
            Console.WriteLine("Liczba znakow w ciagu: " + text.Length);
        }

        // --- ZADANIE 2 ---
        static void Zadanie2_ConnectWords()
        {
            string[] words = new string[5];

            for (int i = 0; i < 5; i++)
            {
                Console.Write($"Podaj wyraz {i + 1}: ");
                words[i] = Console.ReadLine();
            }

            string joinedWords = string.Join(" ", words);
            string finalString = "---" + joinedWords + "---";

            Console.WriteLine("Polaczony tekst: " + finalString);
            Console.WriteLine("Liczba znakow w nowym ciagu: " + finalString.Length);
        }

        // --- ZADANIE 3 ---
        static void Zadanie3_CalculateIntrests()
        {
            Console.Write("Podaj kwote inwestycji (PLN): ");
            double amount = Convert.ToDouble(Console.ReadLine());

            Console.Write("Podaj okres lokaty (w latach): ");
            int years = Convert.ToInt32(Console.ReadLine());

            double interestRate = (amount <= 100000) ? 0.05 : 0.07;
            double finalAmount = amount * Math.Pow(1 + interestRate, years);
            double interestEarned = finalAmount - amount;

            Console.WriteLine($"Oprocentowanie: {interestRate * 100}%");
            Console.WriteLine($"Zarobione odsetki: {Math.Round(interestEarned, 2)} PLN");
            Console.WriteLine($"Kwota koncowa: {Math.Round(finalAmount, 2)} PLN");
        }

        // --- ZADANIE 4 ---
        static void Zadanie4_TriangleData()
        {
            Console.WriteLine("Podaj wspolrzedne 3 punktów (A, B, C).");
            
            Console.Write("xA: "); double xA = Convert.ToDouble(Console.ReadLine());
            Console.Write("yA: "); double yA = Convert.ToDouble(Console.ReadLine());
            
            Console.Write("xB: "); double xB = Convert.ToDouble(Console.ReadLine());
            Console.Write("yB: "); double yB = Convert.ToDouble(Console.ReadLine());
            
            Console.Write("xC: "); double xC = Convert.ToDouble(Console.ReadLine());
            Console.Write("yC: "); double yC = Convert.ToDouble(Console.ReadLine());

            double a = Math.Sqrt(Math.Pow(xB - xA, 2) + Math.Pow(yB - yA, 2));
            double b = Math.Sqrt(Math.Pow(xC - xB, 2) + Math.Pow(yC - yB, 2));
            double c = Math.Sqrt(Math.Pow(xA - xC, 2) + Math.Pow(yA - yC, 2));

            if (a + b > c && a + c > b && b + c > a)
            {
                Console.WriteLine("Punkty tworza trojkat.");

                double perimeter = a + b + c;
                Console.WriteLine($"Obwod trojkata: {Math.Round(perimeter, 2)}");

                double p = perimeter / 2;
                double area = Math.Sqrt(p * (p - a) * (p - b) * (p - c));
                Console.WriteLine($"Pole trojkata: {Math.Round(area, 2)}");

                double[] sides = { a, b, c };
                Array.Sort(sides); 

                if (Math.Abs(Math.Pow(sides[0], 2) + Math.Pow(sides[1], 2) - Math.Pow(sides[2], 2)) < 0.0001)
                {
                    Console.WriteLine("Trojkat jest trojkatem pitagorejskim (prostokatnym).");
                }
                else
                {
                    Console.WriteLine("Trojkat NIE jest trojkatem pitagorejskim.");
                }
            }
            else
            {
                Console.WriteLine("Z podanych punktow nie mozna zbudowac trojkata (leza na jednej prostej).");
            }
        }

        // --- ZADANIE 5 ---
        static void Zadanie5_DateOperations()
        {
            DateTime now = DateTime.Now;

            Console.WriteLine("Aktualna data i czas: " + now.ToString("dd-MM-yyyy HH:mm:ss"));

            DateTime futureDate = now.AddDays(7);
            Console.WriteLine("Data po dodaniu 7 dni: " + futureDate.ToString("dd-MM-yyyy HH:mm:ss"));

            DateTime endOfYear = new DateTime(now.Year, 12, 31, 23, 59, 59);
            TimeSpan timeRemaining = endOfYear - now;
            Console.WriteLine($"Dni do konca biezacego roku: {timeRemaining.Days}");
        }
    }
